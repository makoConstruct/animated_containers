# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
# Libraries should not include pubspec.lock, per https://dart.dev/guides/libraries/private-files#pubspeclock.
/pubspec.lock
**/doc/api/
.dart_tool/
build/
.metadata
analysis_options.yaml
flake.lock
example/pubspec.lock
example/linux

# we don't commit this, because we didn't write any of it, it can be regenerated by flutter create. If we need to customize any of it we'll put exemptions here.
android/*
linux/*
ios/*
web/*
windows/*
macos/*
example/android/*
example/ios/*
example/macos/*
example/linux/*
example/web/*
example/windows/*